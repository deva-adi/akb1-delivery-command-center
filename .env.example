# AKB1 Delivery Command Center v1
# Example environment variables. Copy this file to .env and fill in real values.
# Do not commit .env to git. Last updated for slice 2.2 (M6).

# ==============================================================================
# Postgres bootstrap (creates the akb1_owner and akb1_app roles via init script)
# ==============================================================================
POSTGRES_BOOTSTRAP_USER=postgres
POSTGRES_BOOTSTRAP_PASSWORD=akb1_bootstrap_password
POSTGRES_DB=akb1_dcc
POSTGRES_PORT=5432

# ==============================================================================
# Application database DSNs (asyncpg driver for SQLAlchemy 2 async)
# Two roles per D-036:
#   akb1_app    : runtime connection. SELECT and INSERT on audit_trail_entries.
#                 No UPDATE, no DELETE. Used by FastAPI.
#   akb1_owner  : Alembic migrations. Owns the schema. Subject to FORCE RLS on
#                 audit_trail_entries so even the table owner cannot mutate
#                 existing rows.
# Hostnames: 'db' inside docker-compose, 'localhost' from host.
# ==============================================================================
DATABASE_URL=postgresql+asyncpg://akb1_app:akb1_app_password@localhost:5432/akb1_dcc
DATABASE_URL_MIGRATIONS=postgresql+asyncpg://akb1_owner:akb1_owner_password@localhost:5432/akb1_dcc

# ==============================================================================
# Redis cache and session store
# ==============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ==============================================================================
# Backend service
# ==============================================================================
BACKEND_PORT=8000

# ==============================================================================
# Authentication (JWT in M6 backend; NextAuth in M7 frontend)
# ==============================================================================
JWT_SECRET=replace_with_long_random_string_before_deploy
NEXTAUTH_SECRET=replace_with_long_random_string_before_deploy
NEXTAUTH_URL=http://localhost:3000

# Phase 2 only: OAuth credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ==============================================================================
# Intelligence layer (M6+ optional fallbacks)
# ==============================================================================
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=akb1-local-proxy
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ==============================================================================
# Observability
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==============================================================================
# Feature flags
# ==============================================================================
FEATURE_INTELLIGENCE_LAYER=true
FEATURE_IMPORT_WIZARD=false
FEATURE_AUDIT_LOG=true
