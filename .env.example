# AKB1 Delivery Command Center v1
# Example environment variables
# Copy this file to .env and fill in real values. Do not commit .env to git.
# Placeholder authored 2026-04-24. Real values populated at M6 when backend lands.

# ==============================================================================
# Database
# ==============================================================================
DATABASE_URL=postgresql+psycopg://akb1:akb1_dev_password@localhost:5432/akb1_dcc
POSTGRES_USER=akb1
POSTGRES_PASSWORD=akb1_dev_password
POSTGRES_DB=akb1_dcc

# ==============================================================================
# Cache and session store
# ==============================================================================
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# Authentication
# ==============================================================================
JWT_SECRET=replace_with_long_random_string_before_deploy
NEXTAUTH_SECRET=replace_with_long_random_string_before_deploy
NEXTAUTH_URL=http://localhost:3000

# Phase 2 only: OAuth credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ==============================================================================
# Intelligence layer
# ==============================================================================
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=akb1-local-proxy

# Optional fallback if Ollama is unavailable
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ==============================================================================
# Observability
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==============================================================================
# Feature flags (expanded at M6+)
# ==============================================================================
FEATURE_INTELLIGENCE_LAYER=true
FEATURE_IMPORT_WIZARD=false
FEATURE_AUDIT_LOG=true
