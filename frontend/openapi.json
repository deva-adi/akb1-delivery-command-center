    "/api/v1/audit/search": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Get Audit Search",
        "description": "Search the audit trail with role-scoped row visibility.\n\nFilters: actor_user_id, resource_type, resource_id, http_method, outcome,\ntime_window. Cursor pagination on (occurred_at DESC, entry_id DESC).\n\nScope (per kickoff):\n  - PO/AP=true       -> all rows\n  - PO/AP=false      -> own actions only (actor_user_id = self)\n  - DD/AP=true       -> all rows (programme scoping deferred)\n  - FL/AP=true       -> all rows (programme scoping deferred)\n  - DD/AP=false      -> 403 ApFlagDenied (audit row written)\n  - FL/AP=false      -> 403 ApFlagDenied (audit row written)\n  - PM, HRBP, RO     -> 403 RoleDenied (audit row written)",
        "operationId": "get_audit_search_api_v1_audit_search_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "actor_user_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Actor User Id"
            }
          },
          {
            "name": "resource_type",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 64
                },
                {
                  "type": "null"
                }
              ],
              "title": "Resource Type"
            }
          },
          {
            "name": "resource_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Resource Id"
            }
          },
          {
            "name": "http_method",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^(POST|PUT|PATCH|DELETE)$"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Http Method"
            }
          },
          {
            "name": "outcome",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^(Success|Denied|Error|ApFlagDenied|RoleDenied)$"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Outcome"
            }
          },
          {
            "name": "time_window",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^(1h|24h|7d|30d)$"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Time Window"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200,
              "minimum": 1,
              "default": 50,
              "title": "Page Size"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditSearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/entry/{entry_id}": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Get Audit Entry Detail",
        "description": "Return one audit row including before / after JSON and diff.\n\nStrict AP: every allowed role must have ap_flag=true; PortfolioOwner\nwith AP=false is denied with ApFlagDenied (no own-actions carve-out\nhere because there is no metadata-only fallback).\n\ndiff is the shallow top-level delta between before_json and after_json;\nnull when either side is null.\n\nReads are not audited on success per D-039 ruling 8; denial paths\n(RoleDenied, ApFlagDenied) are audited by require_audit_access.\n404 is returned for an unknown entry_id with no audit row.",
        "operationId": "get_audit_entry_detail_api_v1_audit_entry__entry_id__get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "entry_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Entry Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditEntryDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
