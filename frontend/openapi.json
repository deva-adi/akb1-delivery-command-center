          },
          "occurred_at": {
            "type": "string",
            "format": "date-time",
            "title": "Occurred At"
          },
          "actor_user_id": {
            "type": "string",
            "format": "uuid",
            "title": "Actor User Id"
          },
          "actor_role": {
            "type": "string",
            "title": "Actor Role"
          },
          "http_method": {
            "type": "string",
            "title": "Http Method"
          },
          "endpoint": {
            "type": "string",
            "title": "Endpoint"
          },
          "resource_type": {
            "type": "string",
            "title": "Resource Type"
          },
          "resource_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resource Id"
          },
          "outcome": {
            "type": "string",
            "title": "Outcome"
          },
          "ip_address": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ip Address"
          },
          "before_json": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Before Json"
          },
          "after_json": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "After Json"
          },
          "diff": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AuditEntryDiff"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "entry_id",
          "occurred_at",
          "actor_user_id",
          "actor_role",
          "http_method",
          "endpoint",
          "resource_type",
          "resource_id",
          "outcome",
          "ip_address",
          "before_json",
          "after_json",
          "diff"
        ],
        "title": "AuditEntryDetail",
        "description": "Full audit entry including before / after JSON and server-computed diff.\n\nReturned by GET /api/v1/audit/entry/{entry_id}. The endpoint is gated\non AP=true regardless of role (require_audit_access strict_ap=True).\ndiff is null when either before_json or after_json is null."
      },
      "AuditEntryDiff": {
        "properties": {
          "added": {
            "type": "object",
            "title": "Added",
            "description": "Keys present in after_json but not in before_json."
          },
          "removed": {
            "type": "object",
            "title": "Removed",
            "description": "Keys present in before_json but not in after_json."
          },
          "changed": {
            "additionalProperties": {
              "type": "object"
            },
            "type": "object",
            "title": "Changed",
            "description": "Keys present in both with different values. Each entry is {'before': <prior>, 'after': <new>}."
          }
        },
        "type": "object",
        "title": "AuditEntryDiff",
        "description": "Shallow top-level diff between before_json and after_json.\n\nSlice 5c implementation: top-level keys only. Deep diff (nested object\npaths, array index alignment) is a future enhancement. Each section\nis keyed by the field name; values mirror the original JSON shape."
      },
      "AuditSearchEntry": {
        "properties": {
          "entry_id": {
            "type": "string",
            "format": "uuid",
            "title": "Entry Id"
          },
          "actor_user_id": {
            "type": "string",
            "format": "uuid",
            "title": "Actor User Id"
          },
          "actor_role": {
            "type": "string",
